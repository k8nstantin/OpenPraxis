# Binary
openpraxis
openloom
*.exe
*.test
*.out

# Runtime data directory at repo root (anchored — DO NOT match nested
# `data/` dirs inside the frontend tree, e.g. `dashboard-v2/src/components/
# layout/data/sidebar-data.ts` which is template source code).
/data/

# GoReleaser output (top-level dist/ from `make build-all`)
dist/
# …but the frontend dashboard's dist/ ships a committed stub index.html
# so go:embed always has something to embed on a fresh checkout. The
# inner .gitignore at internal/web/ui/dashboard/.gitignore re-applies
# fine-grained rules (ignore hashed bundles, keep stub).
!internal/web/ui/dashboard/dist/
!internal/web/ui/dashboard-v2/dist/

# Dependencies
vendor/
# …but the frontend's pinned third-party libs (cytoscape, dagre, cytoscape-dagre)
# live at internal/web/ui/vendor/ and MUST be committed so the dashboard
# doesn't silently rely on a CDN. Only the root-level Go vendor/ is ignored.
!internal/web/ui/vendor/

# IDE
.idea/
.vscode/
*.swp
*.swo

# OS
.DS_Store
.env
.env.local

# Config (track example, not actual)
!config.example.yaml

# Local config
.claude/
.mcp.json
agent-memory
mobile/package-lock.json

# Per-task worktrees created by the runner
.openpraxis-work/
openpraxis-darwin-arm64
