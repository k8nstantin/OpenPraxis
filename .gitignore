# Binary
openpraxis
openloom
*.exe
*.test
*.out

# Data directory
data/

# GoReleaser output
dist/

# Dependencies
vendor/
# …but the frontend's pinned third-party libs (cytoscape, dagre, cytoscape-dagre)
# live at internal/web/ui/vendor/ and MUST be committed so the dashboard
# doesn't silently rely on a CDN. Only the root-level Go vendor/ is ignored.
!internal/web/ui/vendor/

# IDE
.idea/
.vscode/
*.swp
*.swo

# OS
.DS_Store
.env
.env.local

# Config (track example, not actual)
!config.example.yaml

